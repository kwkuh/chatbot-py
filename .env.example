# =============================================================================
# chatbot-py — environment configuration
# Copy to .env and fill in the provider(s) you want to use.
# =============================================================================

# --- Pick a default provider --------------------------------------------------
# One of: anthropic | openai | google | ollama
CHATBOT_PROVIDER=anthropic

# --- Anthropic (Claude) -------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- OpenAI (GPT) -------------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here
# Optional: route to any OpenAI-compatible endpoint (Together, Groq, vLLM...)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# --- Google (Gemini) ----------------------------------------------------------
GOOGLE_API_KEY=your-gemini-key

# --- Ollama (local) -----------------------------------------------------------
# Defaults to http://localhost:11434. Override if Ollama runs elsewhere:
# OLLAMA_HOST=http://192.168.1.10:11434

# --- Generation defaults ------------------------------------------------------
# Leave CHATBOT_MODEL unset to use each provider's default.
# CHATBOT_MODEL=claude-sonnet-4-6
CHATBOT_TEMPERATURE=0.7
CHATBOT_MAX_TOKENS=1024
CHATBOT_SYSTEM_PROMPT=You are a helpful assistant.
